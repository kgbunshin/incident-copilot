#!/usr/bin/env bash
# Pre-commit hook — blocks secrets and internal context files from being committed.
# Install: ./scripts/install-hooks.sh

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

ERRORS=0

# ── 1. Blocked filenames ──────────────────────────────────────────────────────
BLOCKED_FILES=(
  ".env"
  ".mcp.json"
  "CLAUDE.md"
  "docs/context.md"
  "docs/handoff.md"
)

for f in "${BLOCKED_FILES[@]}"; do
  if git diff --cached --name-only --diff-filter=ACMR | grep -qxF "$f"; then
    echo -e "${RED}[BLOCKED]${NC} Internal/secret file cannot be committed: $f"
    ERRORS=$((ERRORS + 1))
  fi
done

# ── 2. Blocked filename patterns ─────────────────────────────────────────────
BLOCKED_PATTERNS=(
  "\.env$"
  "\.env\."
  "\.pem$"
  "\.key$"
  "\.p12$"
  "\.pfx$"
  "_rsa$"
  "_ed25519$"
)

for pattern in "${BLOCKED_PATTERNS[@]}"; do
  matches=$(git diff --cached --name-only --diff-filter=ACMR | grep -vFx ".env.example" | grep -iE "$pattern" || true)
  if [[ -n "$matches" ]]; then
    echo -e "${RED}[BLOCKED]${NC} Sensitive file extension detected: $matches"
    ERRORS=$((ERRORS + 1))
  fi
done

# ── 3. Secret patterns inside staged file contents ───────────────────────────
# Only scan added lines (prefix "+") and skip hook and infra-as-code files.
added_lines=$(git diff --cached --unified=0 \
  -- ':!.githooks/*' ':!scripts/install-hooks.sh' ':!ansible/*' \
  | grep "^+" | grep -v "^+++" || true)

SECRET_PATTERNS=(
  "API_SECRET_KEY\s*=\s*[a-f0-9]{32,}"
  "-----BEGIN (RSA|EC|DSA|OPENSSH) PRIVATE KEY"
  "(password|passwd|secret|token)\s*=\s*['\"][^'\"]{8,}"
  "SRE_API_KEY.*[a-f0-9]{32,}"
)

for pattern in "${SECRET_PATTERNS[@]}"; do
  if echo "$added_lines" | grep -qiP "$pattern" 2>/dev/null || \
     echo "$added_lines" | grep -qiE "$pattern" 2>/dev/null; then
    echo -e "${RED}[BLOCKED]${NC} Possible secret in content (pattern: ${pattern:0:40}...)"
    ERRORS=$((ERRORS + 1))
  fi
done

# ── 4. Warn on .claude/ directory ────────────────────────────────────────────
if git diff --cached --name-only | grep -q "^\.claude/"; then
  echo -e "${YELLOW}[WARN]${NC} Files from .claude/ are being committed — make sure there are no secrets."
fi

# ── Result ────────────────────────────────────────────────────────────────────
if [[ $ERRORS -gt 0 ]]; then
  echo ""
  echo -e "${RED}Commit blocked: $ERRORS problem(s) found.${NC}"
  echo "Remove the listed files/content and try again."
  exit 1
fi

exit 0
