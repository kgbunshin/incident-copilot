# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120
OLLAMA_PREWARM=true

# ChromaDB
CHROMA_HOST=http://chromadb:8000
CHROMA_COLLECTION=sre_knowledge

# API
API_BIND_IP=127.0.0.1
API_PORT=8080
API_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32

# Security: comma-separated IPs allowed to reach the API
# Include VPS1 IP, 127.0.0.1, and Docker gateway (172.18.0.1)
TRUSTED_IPS=76.13.165.177,127.0.0.1,172.18.0.1

# Ingestion
INGEST_WATCH_DIR=/data/incoming
LOG_LEVEL=INFO
